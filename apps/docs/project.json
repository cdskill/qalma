{
  "name": "docs",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "prefix": "app",
  "sourceRoot": "apps/docs/src",
  "tags": ["deploy:cloudfront"],
  "targets": {
    "build": {
      "executor": "@analogjs/platform:vite",
      "options": {
        "configFile": "apps/docs/vite.config.ts",
        "main": "apps/docs/src/main.ts",
        "outputPath": "dist/apps/docs/client",
        "tsConfig": "apps/docs/tsconfig.app.json"
      },
      "defaultConfiguration": "production",
      "configurations": {
        "development": {
          "mode": "development"
        },
        "production": {
          "sourcemap": false,
          "mode": "production"
        }
      },
      "outputs": ["{workspaceRoot}/dist/apps/docs"]
    },
    "search-index": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "outputs": ["{workspaceRoot}/dist/apps/docs/analog/public/pagefind"],
      "options": {
        "parallel": false,
        "commands": [
          "pnpm exec pagefind --site dist/apps/docs/analog/public --output-subdir pagefind --include-characters '<>@/_'",
          "node apps/docs/scripts/verify-search-index.mjs"
        ]
      }
    },
    "preview-search": {
      "executor": "nx:run-commands",
      "continuous": true,
      "dependsOn": ["build"],
      "options": {
        "command": "pnpm exec pagefind --site dist/apps/docs/analog/public --output-subdir pagefind --include-characters '<>@/_' --serve"
      }
    },
    "serve": {
      "executor": "@analogjs/platform:vite-dev-server",
      "continuous": true,
      "defaultConfiguration": "development",
      "options": {
        "buildTarget": "docs:build",
        "port": 4200
      },
      "configurations": {
        "development": {
          "buildTarget": "docs:build:development",
          "hmr": true
        },
        "production": {
          "buildTarget": "docs:build:production"
        }
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "serve-static": {
      "continuous": true,
      "executor": "@nx/web:file-server",
      "options": {
        "buildTarget": "docs:build",
        "port": 4200,
        "staticFilePath": "dist/apps/docs/analog/public",
        "spa": true
      }
    },
    "test": {
      "executor": "@analogjs/vitest-angular:test",
      "options": {
        "config": "vite.config.ts"
      }
    }
  }
}
